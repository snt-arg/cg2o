subject to sub_eq_d_lin  {k in K_u} : d_min + h_min*v_h[k+1] <= d_h[k+1];
subject to sub_eq_e_lin  {k in K_u} : d_h[k+1] <= slack_1[k] + h_soft*v_h[k+1];
subject to sub_eq_f_lin  {k in K_u} : b3 <= f_t[k];
subject to sub_eq_g_lin  {k in K_u} : f_t[k] <= b4;
subject to sub_eq_h_lin  {k in K_u} : f_t[k] <= b2 + a2*v_h[k];
subject to sub_eq_i_lin  {k in K_u} : 0 <= f_b[k];
subject to sub_eq_j_1_lin  {k in K_u} : f_b[k] <= Regen_max + b_max;
subject to sub_eq_j_2_lin  {k in K_u} : f_b[k] <= Brems_b1 + b_max + Brems_a1*v_h[k];
subject to sub_eq_k_lin  {k in K_u} : (v_h[k+1])**3 <= (v_max)**3;
subject to sub_eq_l_lin  {k in K_u} : (v_min)**3  <= (v_h[k+1])**3 ;
subject to sub_eq_m_1_lin  {k in {0}} : f_t[k] - f_t_prev <= delta_f_t_max + slack_2[k];
subject to sub_eq_m_2_lin  {k in {0}} : f_t_prev - f_t[k] <= delta_f_t_max + slack_2[k];
subject to sub_eq_m_3_lin  {k in {0 .. N-2}} : f_t[k+1] - f_t[k] <= delta_f_t_max + slack_2[k+1];
subject to sub_eq_m_4_lin  {k in {0 .. N-2}} : f_t[k] - f_t[k+1] <= delta_f_t_max + slack_2[k+1];
subject to sub_eq_n_1_lin  {k in {0}} : f_b[k] - f_b_prev <= delta_f_b_max + slack_3[k];
subject to sub_eq_n_2_lin  {k in {0}} : f_b_prev - f_b[k] <= delta_f_b_max + slack_3[k];
subject to sub_eq_n_3_lin  {k in {0 .. N-2}} : f_b[k+1] - f_b[k] <= delta_f_b_max + slack_3[k+1];
subject to sub_eq_n_4_lin  {k in {0 .. N-2}} : f_b[k] - f_b[k+1] <= delta_f_b_max + slack_3[k+1];
subject to v_initial  {k in {0}} : v_h[k] = v_h_0;
subject to d_initial  {k in {0}} : d_h[k] = d_h_0;
