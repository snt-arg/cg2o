// PERMISSIONS: This is the exact equivalent of --user $(id -u):$(id -g)
// VS Code will automatically adjust the 'cg2o' user's UID/GID to match yours.
"updateRemoteUserUID": true,
"remoteUser": "cg2o",

"containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}",
    // Resolves potential rendering issues in some container environments
    "LIBGL_ALWAYS_SOFTWARE": "1" 
},

"mounts": [
    // Essential for X11/GUI forwarding (RViz, etc.)
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind"
],

"customizations": {
    "vscode": {
        "extensions": [
            "ms-vscode.cpptools",           // IntelliSense, debugging
            "ms-vscode.cmake-tools",        // CMake build management
            "twxs.cmake",                   // CMake syntax highlighting
            "ms-iot.vscode-ros",            // ROS Jazzy support
            "ms-python.python",             // Python support for scripts
            "eamodio.gitlens",              // Git history and insights
            "jeff-hykin.better-cpp-syntax", // Better C++ syntax highlighting
            "streetsidesoftware.code-spell-checker"
        ],
        "settings": {
            "cmake.configureOnOpen": true,
            "cmake.buildDirectory": "${workspaceFolder}/build",
            "python.defaultInterpreterPath": "/usr/bin/python3",
            "ros.distro": "jazzy"
        }
    }
},

// Ensure the user has ownership of the workspace files after setup
"postCreateCommand": "sudo chown -R cg2o:cg2o /ws"
